# Toss Securities Open API credentials
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# Optional: specify an account sequence. If omitted, the brokerage account
# (or the first available account) is selected automatically.
TOSS_ACCOUNT_SEQ=

# Slack webhook notification channels
NOTIFY_ENABLED=true
SLACK_ALERT_ENABLED=false
SLACK_ALERT_WEBHOOK_URL=
SLACK_REPORT_ENABLED=false
SLACK_REPORT_WEBHOOK_URL=
SLACK_LOG_ENABLED=false
SLACK_LOG_WEBHOOK_URL=

# KakaoTalk "send to me" market close reports
# Turn on only after Kakao Developers setup and token issuance are complete.
KAKAO_REPORT_ENABLED=false
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REFRESH_TOKEN=
KAKAO_REDIRECT_URI=http://127.0.0.1:4173/kakao/callback
