# Toss Securities Open API credentials
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# Optional: specify an account sequence. If omitted, the brokerage account
# (or the first available account) is selected automatically.
TOSS_ACCOUNT_SEQ=

# Slack webhook notifications. When SLACK_LOG_WEBHOOK_URL exists, every alert,
# close report and operation report is routed to that one operations-log channel.
NOTIFY_ENABLED=true
# Live analysis loop interval. Default: 10 seconds.
ANALYSIS_INTERVAL_SECONDS=10
# Leave ENABLED blank to turn on automatically when the webhook URL exists.
SLACK_ALERT_ENABLED=
SLACK_ALERT_WEBHOOK_URL=
SLACK_REPORT_ENABLED=
SLACK_REPORT_WEBHOOK_URL=
SLACK_LOG_ENABLED=
SLACK_LOG_WEBHOOK_URL=
# Operational midpoint report interval. Default: 30 minutes.
SLACK_OPERATION_REPORT_INTERVAL_MINUTES=30

# KakaoTalk "send to me" market close reports
# Turn on only after Kakao Developers setup and token issuance are complete.
KAKAO_REPORT_ENABLED=false
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REFRESH_TOKEN=
KAKAO_REDIRECT_URI=http://127.0.0.1:4173/kakao/callback
